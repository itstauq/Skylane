#!/bin/bash
set -euo pipefail

RUNTIME_ROOT="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$RUNTIME_ROOT/.." && pwd)"
SDK_ROOT="$REPO_ROOT/sdk"
TOOLS_DIR="$RUNTIME_ROOT/.build/tools"
NPM_CACHE_DIR="$RUNTIME_ROOT/.build/npm-cache"
NODE_ROOT="$TOOLS_DIR/node"
NODE_BIN="$NODE_ROOT/bin/node"
NPM_BIN="$NODE_ROOT/bin/npm"

bootstrap_node() {
  if [ -x "$NODE_BIN" ]; then
    return
  fi

  mkdir -p "$TOOLS_DIR"

  local version
  version="$(python3 - <<'PY'
import json, urllib.request
with urllib.request.urlopen("https://nodejs.org/dist/index.json") as response:
    versions = json.load(response)
for item in versions:
    version = item["version"]
    if version.startswith("v22."):
        print(version)
        break
PY
)"

  if [ -z "$version" ]; then
    echo "Could not resolve a Node.js v22 release" >&2
    exit 1
  fi

  local machine
  machine="$(uname -m)"

  local node_arch
  case "$machine" in
    arm64|aarch64)
      node_arch="arm64"
      ;;
    x86_64)
      node_arch="x64"
      ;;
    *)
      echo "Unsupported macOS architecture: $machine" >&2
      exit 1
      ;;
  esac

  local archive="node-${version}-darwin-${node_arch}.tar.gz"
  local download_url="https://nodejs.org/dist/${version}/${archive}"
  local temp_archive="$TOOLS_DIR/$archive"

  echo "Downloading local Node runtime ${version} for ${node_arch}..."
  curl -L "$download_url" -o "$temp_archive"
  tar -xzf "$temp_archive" -C "$TOOLS_DIR"
  rm -rf "$NODE_ROOT"
  mv "$TOOLS_DIR/node-${version}-darwin-${node_arch}" "$NODE_ROOT"
  rm -f "$temp_archive"
}

bootstrap_deps() {
  if [ ! -d "$SDK_ROOT/node_modules/notchapp" ]; then
    echo "Installing widget tooling dependencies..."
    "$NPM_BIN" install --prefix "$SDK_ROOT"
  fi
}

bootstrap_node
export PATH="$NODE_ROOT/bin:$PATH"
export npm_config_cache="$NPM_CACHE_DIR"
bootstrap_deps

if [ "${1:-}" = "worker" ]; then
  shift
  exec "$NODE_BIN" "$RUNTIME_ROOT/runtime-worker.mjs" "$@"
fi

exec "$NODE_BIN" "$SDK_ROOT/packages/notchapp/cli.mjs" "$@"
